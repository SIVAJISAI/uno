{
  "name": "uno-multiplayer-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:frontend": "cd frontend && vite --config vite.config.js",
    "dev:server": "node server/src/app.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:server\"",
    "build:frontend": "cd frontend && vite build --config vite.config.js",
    "build": "npm run build:frontend",
    "start": "npm run build:frontend && node server/src/app.js"
  },
  "dependencies": {
    "hono": "^3.4.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.4.1"
  }
}
